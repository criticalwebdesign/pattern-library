---
import Base from "../layouts/Base.astro";
---

<Base
  title="About"
  description="What the Pattern Library is and where it came from."
>
  <h1 class="page-title">About</h1>
  <p class="page-subtitle">
    A browsable library of UI/UX design patterns — screenshots from websites,
    apps, and games — filterable by tag and keyword-searchable.
  </p>

  <div class="prose">
    <p>
      Every entry lives under a website, app, or game and is tagged with the
      interface patterns it demonstrates — onboarding flows, dark patterns,
      empty states, notifications, and more. Browse by group on the
      <a href={import.meta.env.BASE_URL}>homepage</a>, or jump straight to a pattern via the <a
        href={`${import.meta.env.BASE_URL}tags/`}>tags index</a
      >.
    </p>

    <h2>Inspiration</h2>
    <ul>
      <li>
        <a
          href="https://patterntap.com"
          target="_blank"
          rel="noopener noreferrer">patterntap.com</a
        > (RIP)
      </li>
      <li>
        <a
          href="https://gameuidatabase.com"
          target="_blank"
          rel="noopener noreferrer">gameuidatabase.com</a
        >
      </li>
      <li>
        <a
          href="https://interfaceingame.com"
          target="_blank"
          rel="noopener noreferrer">interfaceingame.com</a
        >
      </li>
      <li>
        <a
          href="https://ui-patterns.com/patterns"
          target="_blank"
          rel="noopener noreferrer">ui-patterns.com/patterns</a
        >
      </li>
      <li>
        <a
          href="https://aesthetics.fandom.com/wiki/Aesthetics_Wiki"
          target="_blank"
          rel="noopener noreferrer">Aesthetics Wiki</a
        >
      </li>
    </ul>
  </div>
</Base>
