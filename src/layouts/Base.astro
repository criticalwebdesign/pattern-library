---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'A browsable library of UI design and interface patterns from websites, apps, and games.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} · Pattern Library</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a class="site-title" href={import.meta.env.BASE_URL}>Pattern Library</a>
        <nav class="site-nav">
          <a href={import.meta.env.BASE_URL}>Browse</a>
          <a href={`${import.meta.env.BASE_URL}tags/`}>Tags</a>
          <a href={`${import.meta.env.BASE_URL}about/`}>About</a>
        </nav>
      </div>
    </header>
    <main>
      <div class="container">
        <slot />
      </div>
    </main>
  </body>
</html>
